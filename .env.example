# AI_PROVIDER can be groq, openrouter, github, or gemini
AI_PROVIDER=openrouter

# OpenRouter Configuration
# Get your free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Free OpenRouter Models to Test:
# meta-llama/llama-3.1-8b-instruct:free
# qwen/qwen-2.5-7b-instruct:free
# microsoft/phi-3-mini-128k-instruct:free
# deepseek/deepseek-r1-distill-qwen-7b:free
# google/gemini-2.0-flash:free
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Groq Configuration
# Get your free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# GitHub Models Configuration
# Get your free token at https://github.com/settings/tokens (requires GitHub Models beta access)
# GITHUB_TOKEN=ghp_...
# GITHUB_MODEL=gpt-4o-mini

# Gemini Configuration
# Get your free key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash
